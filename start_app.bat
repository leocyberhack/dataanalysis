@echo off
:: 获取当前批处理脚本所在的绝对路径，并切换到该目录 (解决管理员身份运行时的路径错误问题)
cd /d "%~dp0"

echo ----------------------------------------------------
echo [1/2] 正在启动 FastAPI 后端服务 (端口 8000)...
:: 使用 /B 参数，使后端在当前同一个CMD窗口的后台悄悄运行，不再弹新窗口
start /B python backend\main.py

echo [2/2] 正在启动 React 前端服务 (端口 5173)...
echo ----------------------------------------------------
echo.
echo ====================================================
echo  【注意】前后端服务现在已合并到这"唯一"的一个黑色窗口中！
echo  如果要停止服务并退出程序，请直接【点击右上角 X】关闭本窗口。
echo  数据看板请在浏览器访问: http://localhost:5173
echo ====================================================
echo.

:: 切换到前端目录，并将前端运行状态霸占当前窗口的主线程
cd frontend
npm run dev
